# ═════════════════════════════════════════════════════════════
# ANGELO CLINIC - Configuration d'environnement
# ═════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────
# SERVER
# ─────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─────────────────────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────────────────────
DB_PATH=./angelo-clinic.db

# ─────────────────────────────────────────────────────────────
# JWT & SECURITY
# ─────────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_12345

# ─────────────────────────────────────────────────────────────
# EMAIL CONFIGURATION (Gmail/SMTP)
# ─────────────────────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your-email@gmail.com
MAIL_PASS=your_app_password_not_your_gmail_password
MAIL_FROM=Angelo Clinic <noreply@angelo-clinic.cm>

# Note: Pour Gmail, créer un App Password:
# 1. Activer 2FA sur votre compte Google
# 2. Aller à https://myaccount.google.com/apppasswords
# 3. Générer un mot de passe pour "Mail" et "Windows/Linux"
# 4. Utiliser ce mot de passe comme MAIL_PASS

# ─────────────────────────────────────────────────────────────
# FRONTEND URL (pour CORS)
# ─────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ─────────────────────────────────────────────────────────────
# FEATURES
# ─────────────────────────────────────────────────────────────
ENABLE_SOCKET_IO=true
REMINDER_CHECK_INTERVAL=3600000
